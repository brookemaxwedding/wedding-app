# Copy this file to `.env` and fill in your real values (`.env` is gitignored).
#
# The Apps Script Web App deployment URL (ends in /exec):
VITE_SHEET_URL=https://script.google.com/macros/s/XXXXXXXX/exec
# The shared secret token your Apps Script checks on reads/writes:
VITE_SHEET_TOKEN=your-secret-token
